model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  nickname  String?
  phone     String?
  avatar    String?
  email     String?
  gender    Int      @default(0)
  remark    String?
  status    Boolean  @default(true)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles UserRole[]

  @@map("users")
}
